# Server Configuration
PORT=3000
NODE_ENV=development
# Log level: fatal|error|warn|info|debug|trace. Use warn or error in production.
LOG_LEVEL=info

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI Configuration (optional at startup; required when AI features are used)
OPENAI_API_KEY=your_openai_api_key
# Model for intent/response (audit and cost tracking); default: gpt-5.2 (flagship)
OPENAI_MODEL=gpt-5.2
# Max tokens for completion (cost control); default: 256
OPENAI_MAX_TOKENS=256

# Post–medical-deflection payment-existence DM ack: when unset or not "false"/"0", canonical English is localized via OpenAI using the user's language. Set to false for English-only or tests.
# POST_MEDICAL_ACK_AI_LOCALIZE=false

# Reason-first “noted reasons” / confirm snippet: **leave unset in production** (→ OpenAI JSON extraction in
# resolveVisitReasonSnippetForTriage). Deterministic distillation is only a safety fallback; do not rely on it
# for new patient phrasings (see docs/Reference/AI_BOT_BUILDING_PHILOSOPHY.md). Set false for local/tests only.
# VISIT_REASON_SNIPPET_AI_ENABLED=false

# Clinical-led fee DM: before deferring ambiguous catalog rows to staff, try allowlist LLM match once (multi-row teleconsult catalog).
# FEE_DM_CATALOG_LLM_NARROW_ENABLED=false

# book_for_someone_else: when regex kin match is missing or generic, one OpenAI JSON call for relation label (e.g. grandmother, friend).
# BOOKING_RELATION_LLM_ENABLED=false

# Staff feedback learning (learn-02): persist service_match_learning_examples on staff confirm/reassign. Set false to disable ingest.
# SERVICE_MATCH_LEARNING_INGEST_ENABLED=false

# Staff feedback shadow (learn-03): hypothetical suggestion when a pending staff review row is created. Set false to disable.
# SHADOW_LEARNING_ENABLED=false

# learn-04: policy suggestion thresholds (stable reassignment RPC); optional email when a new suggestion row is inserted.
# LEARNING_POLICY_MIN_RESOLUTIONS=5
# LEARNING_POLICY_WINDOW_DAYS=30
# LEARNING_POLICY_SNOOZE_DAYS=14
# LEARNING_POLICY_SUGGESTION_EMAIL_ENABLED=false

# learn-05: apply saved autobook policies when structured pattern matches (skip staff review). Kill switch:
# LEARNING_AUTOBOOK_ENABLED=false

# Plan 03 · Task 11 Phase 1 — emit one-shot structured warnings at every classified legacy
# `appointment_fee_minor` call site. Default OFF (production quiet). Flip to `true` in dev/staging.
# See docs/Development/Architecture/legacy-appointment-fee-minor-deprecation.md
# DEPRECATION_WARNINGS_ENABLED=true


# Webhook URL (for local development, use ngrok)
WEBHOOK_URL=http://localhost:3000

# Redis / Webhook Queue (optional - leave unset to use placeholder queue)
REDIS_URL=redis://localhost:6379
WEBHOOK_WORKER_CONCURRENCY=5

# Encryption (required when using webhooks and dead letter queue - payloads are encrypted at rest)
# Base64-encoded 32-byte key (256 bits for AES-256). Generate e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Multi-doctor: each doctor connects Instagram via dashboard (Settings); webhook uses page_id → doctor_id resolution. Not used in production.
# DEFAULT_DOCTOR_ID=  (deprecated; do not use)
# Default doctor country for payment routing: IN=India (Razorpay), US/UK/EU=PayPal
# Used when doctor has no row in doctor_settings (e-task-4.1)
DEFAULT_DOCTOR_COUNTRY=IN
# Appointment fee fallback when doctor has no settings (optional). Doctors should set fee in Dashboard > Booking Rules.
# Leave unset or 0; patients won't get payment links until doctor configures fee.
# APPOINTMENT_FEE_MINOR=50000
APPOINTMENT_FEE_CURRENCY=INR

# Notifications (e-task-5): email via Resend; doctor email fallback when not in auth
RESEND_API_KEY=
DEFAULT_DOCTOR_EMAIL=

# Payment Gateways (e-task-4)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay Route (payout): uses same keys. Enable Route in Razorpay Dashboard; add Linked Accounts for doctors.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# Booking slot picker (e-task-3 - external page; token auth)
# Secret for signing booking tokens (min 16 chars). Generate: openssl rand -base64 24
BOOKING_TOKEN_SECRET=NzIN6YyQvFspI7K+hfR9TDEoqpWWPjDF
# URL of slot picker page (e.g. https://app.example.com/book)
BOOKING_PAGE_URL=https://clariva-bot.vercel.app/book

# Instagram Configuration (Facebook Login / Page-linked path - e-task-1 Week 3)
# Use Meta/Facebook app credentials. Instagram must be linked to a Facebook Page.
# Add callback URL to Facebook app's Valid OAuth Redirect URIs in Meta dashboard.
INSTAGRAM_APP_ID=your_meta_app_id
INSTAGRAM_APP_SECRET=your_meta_app_secret
# Optional when doctors connect via OAuth (e-task-14). Used as fallback e.g. for reply to unknown page when no doctor linked.
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_min_32_chars
# INSTAGRAM_PAGE_ID= (deprecated; multi-doctor uses doctor_instagram table; each doctor connects via dashboard)
# OAuth connect flow: full callback URL (e.g. https://your-api.com/api/v1/settings/instagram/callback)
INSTAGRAM_REDIRECT_URI=https://your-api.com/api/v1/settings/instagram/callback
# After successful connect, redirect browser here (optional; if unset, callback returns JSON)
INSTAGRAM_FRONTEND_REDIRECT_URI=https://your-app.com/dashboard/settings/instagram

# Meta subscribe script (npm run meta:subscribe) - for comment webhooks when dashboard isn't enough
# Do NOT commit real values. Get from Meta Dashboard → Instagram settings → Page table + Generate token
# META_PAGE_ID=your_facebook_page_id
# META_PAGE_ACCESS_TOKEN=your_page_access_token

# Twilio (SMS, Video teleconsultation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Video access tokens: create API Key in Twilio Console (US1 region required for Video)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Teleconsultation (e-task-3 - patient join link)
# Secret for signing patient join tokens (min 16 chars). Generate: openssl rand -base64 24
CONSULTATION_TOKEN_SECRET=
# Base URL for the **video** legacy patient join page (`?token=` HMAC shape).
# Text + voice patient links use `APP_BASE_URL` in env.ts when set; if you
# only configure one public URL for the Next.js app, set **both** this and
# `APP_BASE_URL` to that origin (e.g. https://clariva-bot.vercel.app) so
# `sendConsultationReadyToPatient` can build `/c/text/...` and `/c/voice/...`.
CONSULTATION_JOIN_BASE_URL=
# Next.js app origin (text/voice deep links, DM join URLs). Prefer same value
# as CONSULTATION_JOIN_BASE_URL when both point at the same deployment.
# APP_BASE_URL=https://your-app.vercel.app

# Supabase project JWT secret (Plan 04 — text consults).
# From Supabase Dashboard → Project Settings → API → "JWT Secret".
# REQUIRED for text consults: without it, /start-text runs fine for the doctor
# but `sendConsultationReadyToPatient` (and `/resend-link`) cannot mint the
# scoped patient JWT, so the IG DM / email / SMS with the `/c/text/...?t=...`
# join link is silently skipped (logs: "Consultation-ready fan-out skipped
# (join-token mint failed)"). Min 16 chars.
# SUPABASE_JWT_SECRET=

# Teleconsultation (e-task-4 - Twilio status callbacks)
# Backend base URL for Twilio to call (e.g. https://your-api.onrender.com)
WEBHOOK_BASE_URL=
# Min consultation duration (seconds) to mark verified for payout; default 60
# MIN_VERIFIED_CONSULTATION_SECONDS=60

# Platform Fee (monetization - migration 022)
# Percent when amount >= threshold; flat when amount < threshold. All amounts in paise (INR).
# PLATFORM_FEE_PERCENT=5
# PLATFORM_FEE_FLAT_MINOR=2500
# PLATFORM_FEE_THRESHOLD_MINOR=50000
# PLATFORM_FEE_GST_PERCENT=18

# Cron (e-task-5): secret for scheduled payouts. Render cron: curl -X POST -H "Authorization: Bearer $CRON_SECRET" https://api/cron/payouts
# CRON_SECRET=