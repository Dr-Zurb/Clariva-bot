# Backend API base URL (e.g. http://localhost:3001), no trailing slash.
# Required for the browser and for server components (dashboard data fetching).
NEXT_PUBLIC_API_URL=

# Optional: override API host for server-side fetch only (e.g. internal URL on Vercel).
# If unset, server code uses NEXT_PUBLIC_API_URL.
# API_URL=
# BACKEND_API_URL=

# Supabase project URL (used in Task 2: Supabase Auth)
# Get from Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key (used in Task 2: Supabase Auth)
# Safe to expose in the browser; never put service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay Checkout SDK public key (Plan 09 · Task 50 — mid-consult upgrade modal).
# Format: rzp_test_XXXXXXXX (test) or rzp_live_XXXXXXXX (prod). Exposed in the
# browser — this is Razorpay's public key, NOT the secret. Required for
# <ModalityUpgradeRequestModal> to open the in-app checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional: E2E tests (Playwright). Use test account only; never production.
# Tests run the app on port 3002 by default. Quote E2E_PASSWORD if it contains # (e.g. E2E_PASSWORD="pass#123").
# E2E_USER=
# E2E_PASSWORD=
