# Backend API base URL (e.g. http://localhost:3001), no trailing slash.
# Required for production and for server-side fetch in `next start`.
# In `next dev`, the browser on localhost (or a *.ts.net Funnel hostname) uses
# same-origin `/api/v1/...` automatically — localhost is proxied to :3001 via
# next.config.mjs rewrites; Funnel path-routes to the local backend.
NEXT_PUBLIC_API_URL=

# Optional: override API host for server-side fetch only (e.g. internal URL on Vercel).
# If unset, server code uses NEXT_PUBLIC_API_URL.
# API_URL=
# BACKEND_API_URL=

# Supabase project URL (used in Task 2: Supabase Auth)
# Get from Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key (used in Task 2: Supabase Auth)
# Safe to expose in the browser; never put service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay Checkout SDK public key (Plan 09 · Task 50 — mid-consult upgrade modal).
# Format: rzp_test_XXXXXXXX (test) or rzp_live_XXXXXXXX (prod). Exposed in the
# browser — this is Razorpay's public key, NOT the secret. Required for
# <ModalityUpgradeRequestModal> to open the in-app checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Web Push (task-text-D6a): VAPID public key for browser subscribe() call.
# Must match backend WEB_PUSH_VAPID_PUBLIC_KEY. Wired in D6b opt-in flow.
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# Voice consult background-noise suppression (task-voice-C9).
# Krisp + per-doctor opt-in (defaulted ON) per plan §9. Same-origin path
# to the Krisp/RNNoise WASM bundle (e.g. "/krisp"). Required for the
# toggle to be surfaced; when unset the feature is silently unavailable
# and Twilio falls back to a vanilla mic track. See
# frontend/lib/audio/noise-suppression.ts.
NEXT_PUBLIC_NOISE_SUPPRESSION_ASSETS_PATH=
# Vendor identifier. Accepted values: "krisp" (default) or "rnnoise".
# Must match the WASM bundle hosted at the path above.
NEXT_PUBLIC_NOISE_SUPPRESSION_VENDOR=krisp

# Clinical region for cockpit passive hints (social history thresholds, etc.).
# IN = India (launch default) · UK · US · EU. See docs/Reference/engineering/REGION-SPECIFIC-CONFIG.md
# NEXT_PUBLIC_CLINICAL_REGION=IN

# Optional: E2E tests (Playwright). Use test account only; never production.
# Tests run the app on port 3002 by default. Quote E2E_PASSWORD if it contains # (e.g. E2E_PASSWORD="pass#123").
# E2E_USER=
# E2E_PASSWORD=
