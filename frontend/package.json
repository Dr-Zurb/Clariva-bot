{
  "name": "clariva-bot-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Clariva Doctor Dashboard - Next.js frontend",
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "node scripts/start-dev-with-env.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:existing-server": "node scripts/run-e2e-existing-server.js",
    "test:e2e:existing-server:headed": "node scripts/run-e2e-existing-server.js -- --headed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "postinstall": "node scripts/copy-twilio-video-processors-assets.mjs"
  },
  "engines": {
    "node": "18.x || 20.x || 22.x"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
