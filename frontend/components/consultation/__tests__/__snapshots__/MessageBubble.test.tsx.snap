// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`MessageBubble snapshots > renders a doctor text message 1`] = `
<div>
  <ul>
    <li
      class="group/message relative flex flex-col items-end"
      data-message-id="msg-001"
      role="listitem"
    >
      <p
        class="mb-0.5 flex items-center gap-1 px-1 text-[11px] text-gray-500"
      >
        <span>
          15:45
        </span>
      </p>
      <div
        class="max-w-[80%] message-body whitespace-pre-wrap break-words rounded-2xl px-3 py-2 text-sm shadow-sm bg-blue-600 text-white"
      >
        <span
          class="inline-flex w-full flex-wrap items-end gap-x-1"
        >
          <span
            class="min-w-0 flex-1"
          >
            Plan discussed — follow up in two weeks.
          </span>
          <span
            aria-label="Delivered"
            class="text-gray-500 text-xs ml-1 shrink-0"
          >
            ✓
          </span>
        </span>
      </div>
    </li>
  </ul>
</div>
`;

exports[`MessageBubble snapshots > renders a failed-send bubble 1`] = `
<div>
  <ul>
    <li
      class="group/message relative flex flex-col items-end border-l-2 border-red-300 pl-2"
      data-failed="true"
      data-message-id="msg-failed"
      role="listitem"
    >
      <p
        class="mb-0.5 flex items-center gap-1 px-1 text-[11px] text-gray-500"
      >
        <span>
          15:45
        </span>
      </p>
      <div
        class="max-w-[80%] message-body whitespace-pre-wrap break-words rounded-2xl px-3 py-2 text-sm shadow-sm bg-blue-600 text-white"
      >
        <span
          class="inline-flex w-full flex-wrap items-end gap-x-1"
        >
          <span
            class="min-w-0 flex-1"
          >
            Message that failed to send.
          </span>
        </span>
      </div>
      <div
        class="mt-1 flex items-center gap-2 text-xs text-red-700"
      >
        <span>
          Failed to send
        </span>
        <button
          class="underline hover:text-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1"
          type="button"
        >
          Retry
        </button>
        <button
          class="underline hover:text-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1"
          type="button"
        >
          Discard
        </button>
      </div>
    </li>
  </ul>
</div>
`;

